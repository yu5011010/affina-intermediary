# EC の AFFINA_API_SECRET と同じ値にする
AFFINA_INBOUND_SECRET=sk_demo_sample_do_not_use_in_production

# 仲介アプリの DB（EC と同様に Supabase JS / anon キーで接続）
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# （任意）drizzle-kit generate 用。アプリ実行時は不要
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres?pgbouncer=true
